${e}`)}}}return s.length>0&&a.push("The following project files have been modified from the default template:\n\n"+s.join("\n\n")),a.join("\n\n")}(e,n);if(0===a.length)return void t();let l=(r=a?"\nThe user has applied the following configuration changes, in the diff below. These are to be treated as the baseline for the setup guidelines:\n"+a:"",(i||eB).replace(eG,r));o.zl.set(eR.gU,{message:l})}catch{n()}}),(0,r.jsx)("div",{...h.xk(ea.l.stepContent),children:(0,r.jsx)("span",{...h.xk(ea.l.subtext),children:(0,X.t)("figmake.import_progress.section.generating_setup_guidelines.subtext")})})}function eH({baselineFiles:e,setBaselineFiles:t}){let n=(0,P.I0)();return(0,eI.h)(()=>{var r;let a=ez(n),i=eU(e,a),s=(r=function(e,t){let n={};try{n=JSON.parse(e)}catch{}let r=new Set(t),a={};for(let e of eW){let t=n[e];if(t&&"object"==typeof t)for(let[n,i]of Object.entries(t))r.has(n)&&(a[e]??={},a[e][n]=i)}return a}(a["/package.json"]??"{}",i),`## Package Installation

**CRITICAL**: All packages listed below MUST be installed. Do not assume it already exists. Use the exact package name listed. Do not skip this step or substitute a different package name.

Add the following to your \`package.json\` dependencies:

\`\`\`json
